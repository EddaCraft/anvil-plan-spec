#!/usr/bin/env bash
#
# APS CLI - Anvil Plan Spec tooling
#
# Usage:
#   aps init [dir]        Create APS structure in a new project (v2 layout)
#   aps update [dir]      Update templates, skill, and tool files
#   aps migrate [dir]     Convert v1 layout to v2
#   aps lint [file|dir]   Validate APS documents (default: plans/)
#   aps lint --json       Output as JSON
#   aps --help            Show this help
#

set -eo pipefail

# Resolve through symlinks so global installs find lib/
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
LIB_DIR="$SCRIPT_DIR/../lib"

# Source library files
source "$LIB_DIR/output.sh"
source "$LIB_DIR/rules/common.sh"
source "$LIB_DIR/rules/module.sh"
source "$LIB_DIR/rules/index.sh"
source "$LIB_DIR/rules/workitem.sh"
source "$LIB_DIR/rules/issues.sh"
source "$LIB_DIR/rules/design.sh"
source "$LIB_DIR/lint.sh"
source "$LIB_DIR/scaffold.sh"
source "$LIB_DIR/orch.sh"

show_help() {
  cat <<EOF
aps - Anvil Plan Spec CLI

Usage:
  aps init [dir]        Create APS structure in a new project (v2 layout)
  aps update [dir]      Update templates, skill, and tool files
  aps migrate [dir]     Convert v1 layout to v2 (.aps/ consolidation)
  aps lint [file|dir]   Validate APS documents
  aps lint --json       Output results as JSON
  aps next [module]     Print next Ready work item with all deps Complete
  aps next --json       Emit JSON instead of human-readable output
  aps --help            Show this help

Options:
  --json    Output results in JSON format
  --help    Show help for a command

Environment:
  APS_VERSION   Git ref to download from (default: main)

Examples:
  aps init                    # Interactive wizard (v2 layout)
  aps init --profile solo --scope small --tools claude-code
  aps update                  # Update templates and tool files
  aps migrate                 # Convert v1 -> v2
  aps migrate --dry-run       # Preview migration
  aps lint                    # Lint plans/ directory
  aps lint plans/index.aps.md # Lint specific file
  aps lint . --json           # Lint current dir, JSON output
  aps next                    # Next Ready work item across plans/
  aps next orch               # Next Ready work item in the orch module
  aps next --json             # JSON output for tooling
EOF
}

cmd_next() {
  local plans_dir="plans"
  local filter=""
  local json=0

  while (($#)); do
    case "$1" in
      --json) json=1; shift ;;
      --plans-dir)
        if [[ -z "${2:-}" ]]; then
          error "--plans-dir requires an argument"
          return 1
        fi
        plans_dir="$2"
        shift 2
        ;;
      -h|--help)
        cat <<EOF
aps next - Print the next Ready work item whose dependencies are all Complete

Usage:
  aps next [module] [--json] [--plans-dir <dir>]

Examples:
  aps next                 # Pick across all modules
  aps next orch            # Restrict to a module (filename match)
  aps next --json          # Machine-readable output

Exit code:
  0   A candidate was found
  1   No candidate is currently startable
EOF
        return 0
        ;;
      *) filter="$1"; shift ;;
    esac
  done

  if [[ ! -d "$plans_dir/modules" ]]; then
    error "No modules directory at '$plans_dir/modules'"
    return 1
  fi

  local row
  if ! row="$(orch_resolve_next "$plans_dir" "$filter")"; then
    if (( json == 1 )); then
      printf '{"found":false}\n'
    else
      info "No Ready work items with all dependencies Complete"
    fi
    return 1
  fi

  IFS=$'\t' read -r f id title status deps <<< "$row"
  local module
  module="$(basename "$f" .aps.md)"

  if (( json == 1 )); then
    if ! command -v jq >/dev/null 2>&1; then
      error "aps next --json requires jq on PATH"
      return 1
    fi
    local deps_args=()
    if [[ -n "$deps" ]]; then
      local IFS_OLD="$IFS"
      IFS=',' read -ra _dep_arr <<< "$deps"
      IFS="$IFS_OLD"
      deps_args=("${_dep_arr[@]}")
    fi
    jq -cn \
      --arg id "$id" \
      --arg module "$module" \
      --arg title "$title" \
      --arg status "$status" \
      --arg file "$f" \
      --args \
      '{found:true, id:$id, module:$module, title:$title, status:$status, dependencies:$ARGS.positional, file:$file}' \
      "${deps_args[@]}"
  else
    printf '%s — %s\n' "$id" "$title"
    printf '  Module: %s\n' "$module"
    if [[ -n "$deps" ]]; then
      printf '  Dependencies (Complete): %s\n' "$deps"
    else
      printf '  Dependencies: none\n'
    fi
    printf '  File: %s\n' "$f"
  fi
}

main() {
  local cmd="${1:-}"

  case "$cmd" in
    init)
      shift
      cmd_init "$@"
      ;;
    update)
      shift
      cmd_update "$@"
      ;;
    migrate)
      shift
      cmd_migrate "$@"
      ;;
    lint)
      shift
      cmd_lint "$@"
      ;;
    next)
      shift
      cmd_next "$@"
      ;;
    --help|-h|help|"")
      show_help
      exit 0
      ;;
    *)
      error "Unknown command: $cmd"
      echo "Run 'aps --help' for usage."
      exit 1
      ;;
  esac
}

main "$@"
